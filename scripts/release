#!/usr/bin/env bash
set -euo pipefail

BUMP_TYPE="${1:-}"
GEM_NAME="rubocop-sane_conditionals"
VERSION_FILE="lib/rubocop-sane_conditionals/version.rb"

if [[ "$BUMP_TYPE" != "major" && "$BUMP_TYPE" != "minor" && "$BUMP_TYPE" != "patch" ]]; then
	echo "Usage: scripts/release <major|minor|patch>"
	exit 1
fi

# Ensure working directory is clean
if [[ -n "$(git status --porcelain)" ]]; then
	echo "Error: working directory is not clean. Commit or stash changes first."
	exit 1
fi

# Read current version
CURRENT_VERSION=$(ruby -r "./lib/rubocop-sane_conditionals/version" -e "puts RuboCop::SaneConditionals::VERSION")
IFS='.' read -r MAJOR MINOR PATCH <<<"$CURRENT_VERSION"

echo "Current version: $CURRENT_VERSION"

# Compute new version
case "$BUMP_TYPE" in
major)
	MAJOR=$((MAJOR + 1))
	MINOR=0
	PATCH=0
	;;
minor)
	MINOR=$((MINOR + 1))
	PATCH=0
	;;
patch)
	PATCH=$((PATCH + 1))
	;;
esac

NEW_VERSION="$MAJOR.$MINOR.$PATCH"
echo "New version:     $NEW_VERSION"

# Update version file
sed -i '' "s/VERSION = '${CURRENT_VERSION}'/VERSION = '${NEW_VERSION}'/" "$VERSION_FILE"

# Run tests before releasing
echo "Running tests..."
bundle exec rspec
echo "Tests passed."

# Commit, tag, and push
git add "$VERSION_FILE"
git commit -m "Bump version to $NEW_VERSION"
git tag "v$NEW_VERSION"
git push origin HEAD --tags

# Build and push gem
gem build "$GEM_NAME.gemspec"
gem push "$GEM_NAME-$NEW_VERSION.gem"
rm -f "$GEM_NAME-$NEW_VERSION.gem"

echo "Released $GEM_NAME $NEW_VERSION"
